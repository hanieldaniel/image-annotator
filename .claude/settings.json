{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | grep -qE '\\.(ts|js)$' && npm run build 2>&1 || true",
            "statusMessage": "Building..."
          }
        ]
      }
    ]
  }
}
